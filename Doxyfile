# Doxyfile for FSLint Doxygen Check

PROJECT_NAME           = "FSLint"
OUTPUT_DIRECTORY       =
CREATE_SUBDIRS         = NO
ALLOW_UNICODE_NAMES    = YES
OUTPUT_LANGUAGE        = English
BRIEF_MEMBER_DESC      = YES
REPEAT_BRIEF           = YES

# Input settings
INPUT                  = core \
                         cli \
                         wasm
RECURSIVE              = YES
FILE_PATTERNS          = *.h
EXCLUDE                =
EXCLUDE_PATTERNS       =

# Extraction settings
EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = NO
EXTRACT_PACKAGE        = NO
EXTRACT_STATIC         = NO
EXTRACT_LOCAL_CLASSES  = NO
EXTRACT_LOCAL_METHODS  = NO
EXTRACT_ANON_NSPACES   = NO

# Warning settings
QUIET                  = YES
WARNINGS               = YES
WARN_IF_DOC_ERROR      = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_AS_ERROR          = YES

# Disable generation
GENERATE_HTML          = NO
GENERATE_LATEX         = NO
GENERATE_XML           = NO
