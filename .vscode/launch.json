{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Tests",
            "request": "launch",
            "program": "${command:cmake.launchTargetPath}",
            "args": [],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "type": "cppdbg",
            "linux": {
                "MIMode": "gdb",
                "miDebuggerPath": "/usr/bin/gdb",
                "setupCommands": [
                    {
                        "description": "Enable pretty-printing for gdb",
                        "text": "-enable-pretty-printing",
                        "ignoreFailures": true
                    }
                ]
            },
            "osx": {
                "type": "lldb"
            },
            "windows": {
                "type": "cppvsdbg"
            },
            "preLaunchTask": "Build Current Project"
        },
        {
            "name": "Debug FMU/SSP",
            "request": "launch",
            "program": "${command:cmake.launchTargetPath}",
            "args": [
                "${input:operation}",
                "${input:fmuFile}"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "type": "cppdbg",
            "linux": {
                "MIMode": "gdb",
                "miDebuggerPath": "/usr/bin/gdb",
                "setupCommands": [
                    {
                        "description": "Enable pretty-printing for gdb",
                        "text": "-enable-pretty-printing",
                        "ignoreFailures": true
                    }
                ]
            },
            "osx": {
                "type": "lldb"
            },
            "windows": {
                "type": "cppvsdbg"
            },
            "preLaunchTask": "Build Current Project"
        }
    ],
    "inputs": [
        {
            "id": "operation",
            "type": "pickString",
            "description": "Operation",
            "options": [
                "",
                "-s",
                "-u",
                "-r",
                "-d"
            ],
            "default": ""
        },
        {
            "id": "fmuFile",
            "type": "pickString",
            "description": "Select FMU / SSP file",
            "options": [
                "${workspaceFolder}/models/Reference-FMUs-0.0.39/1.0/CS/BouncingBall.fmu",
                "${workspaceFolder}/models/Reference-FMUs-0.0.39/1.0/CS/Dahlquist.fmu",
                "${workspaceFolder}/models/Reference-FMUs-0.0.39/1.0/CS/Feedthrough.fmu",
                "${workspaceFolder}/models/Reference-FMUs-0.0.39/1.0/CS/Resource.fmu",
                "${workspaceFolder}/models/Reference-FMUs-0.0.39/1.0/CS/Stair.fmu",
                "${workspaceFolder}/models/Reference-FMUs-0.0.39/1.0/CS/VanDerPol.fmu",
                "${workspaceFolder}/models/Reference-FMUs-0.0.39/1.0/ME/BouncingBall.fmu",
                "${workspaceFolder}/models/Reference-FMUs-0.0.39/1.0/ME/Dahlquist.fmu",
                "${workspaceFolder}/models/Reference-FMUs-0.0.39/1.0/ME/Feedthrough.fmu",
                "${workspaceFolder}/models/Reference-FMUs-0.0.39/1.0/ME/Resource.fmu",
                "${workspaceFolder}/models/Reference-FMUs-0.0.39/1.0/ME/Stair.fmu",
                "${workspaceFolder}/models/Reference-FMUs-0.0.39/1.0/ME/VanDerPol.fmu",

                "${workspaceFolder}/models/Reference-FMUs-0.0.39/2.0/BouncingBall.fmu",
                "${workspaceFolder}/models/Reference-FMUs-0.0.39/2.0/Dahlquist.fmu",
                "${workspaceFolder}/models/Reference-FMUs-0.0.39/2.0/Feedthrough.fmu",
                "${workspaceFolder}/models/Reference-FMUs-0.0.39/2.0/Resource.fmu",
                "${workspaceFolder}/models/Reference-FMUs-0.0.39/2.0/Stair.fmu",
                "${workspaceFolder}/models/Reference-FMUs-0.0.39/2.0/VanDerPol.fmu",

                "${workspaceFolder}/models/Reference-FMUs-0.0.39/3.0/BouncingBall.fmu",
                "${workspaceFolder}/models/Reference-FMUs-0.0.39/3.0/Clocks.fmu",
                "${workspaceFolder}/models/Reference-FMUs-0.0.39/3.0/Dahlquist.fmu",
                "${workspaceFolder}/models/Reference-FMUs-0.0.39/3.0/Feedthrough.fmu",
                "${workspaceFolder}/models/Reference-FMUs-0.0.39/3.0/Resource.fmu",
                "${workspaceFolder}/models/Reference-FMUs-0.0.39/3.0/Stair.fmu",
                "${workspaceFolder}/models/Reference-FMUs-0.0.39/3.0/StateSpace.fmu",
                "${workspaceFolder}/models/Reference-FMUs-0.0.39/3.0/VanDerPol.fmu",

                "${workspaceFolder}/models/PneumaticCylinderController3.fmu"
            ],
            "default": "${workspaceFolder}/models/Reference-FMUs-0.0.39/3.0/BouncingBall.fmu"
        }
    ]
}
