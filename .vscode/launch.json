{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug FMU/SSP (Windows)",
            "request": "launch",
            "program": "${workspaceFolder}\\build\\windows-clang-debug\\FSLint-cli.exe",
            "args": [
                "${input:operation}",
                "${input:fmuFile}"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "type": "cppvsdbg",
            "preLaunchTask": "Build Current Project"
        },
        {
            "name": "Debug FMU/SSP (macOS)",
            "request": "launch",
            "program": "${workspaceFolder}/build/macos-clang-debug/FSLint-cli",
            "args": [
                "${input:operation}",
                "${input:fmuFile}"
            ],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Build Current Project",
            "console": "integratedTerminal",
            "type": "lldb"
        },
        {
            "name": "Debug FMU/SSP (Linux)",

            "request": "launch",
            "program": "${workspaceFolder}/build/linux-clang-debug/FSLint-cli",
            "args": [
                "${input:operation}",
                "${input:fmuFile}"
            ],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Build Current Project",
            "type": "cppdbg",
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        },
        {
            "name": "Debug Tests (Windows)",
            "request": "launch",
            "program": "${workspaceFolder}\\build\\windows-clang-debug\\FSLint-tests.exe",
            "args": [],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "type": "cppvsdbg",
            "preLaunchTask": "Build Current Project"
        },
        {
            "name": "Debug Tests (macOS)",
            "request": "launch",
            "program": "${workspaceFolder}/build/macos-clang-debug/FSLint-tests",
            "args": [],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Build Current Project",
            "console": "integratedTerminal",
            "type": "lldb"
        },
        {
            "name": "Debug Tests (Linux)",
            "request": "launch",
            "program": "${workspaceFolder}/build/linux-clang-debug/FSLint-tests",
            "args": [],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Build Current Project",
            "type": "cppdbg",
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        }
    ],
    "inputs": [
        {
            "id": "operation",
            "type": "pickString",
            "description": "Operation",
            "options": [
                "",
                "-s",
                "-u",
                "-r",
                "-d"
            ],
            "default": ""
        },
        {
            "id": "fmuFile",
            "type": "pickString",
            "description": "Select FMU / SSP file",
            "options": [
                "${workspaceFolder}/models/Reference-FMUs-0.0.39/2.0/BouncingBall.fmu",
                "${workspaceFolder}/models/Reference-FMUs-0.0.39/2.0/Dahlquist.fmu",
                "${workspaceFolder}/models/Reference-FMUs-0.0.39/2.0/Feedthrough.fmu",
                "${workspaceFolder}/models/Reference-FMUs-0.0.39/2.0/Resource.fmu",
                "${workspaceFolder}/models/Reference-FMUs-0.0.39/2.0/Stair.fmu",
                "${workspaceFolder}/models/Reference-FMUs-0.0.39/2.0/VanDerPol.fmu",

                "${workspaceFolder}/models/Reference-FMUs-0.0.39/3.0/BouncingBall.fmu",
                "${workspaceFolder}/models/Reference-FMUs-0.0.39/3.0/Clocks.fmu",
                "${workspaceFolder}/models/Reference-FMUs-0.0.39/3.0/Dahlquist.fmu",
                "${workspaceFolder}/models/Reference-FMUs-0.0.39/3.0/Feedthrough.fmu",
                "${workspaceFolder}/models/Reference-FMUs-0.0.39/3.0/Resource.fmu",
                "${workspaceFolder}/models/Reference-FMUs-0.0.39/3.0/Stair.fmu",
                "${workspaceFolder}/models/Reference-FMUs-0.0.39/3.0/StateSpace.fmu",
                "${workspaceFolder}/models/Reference-FMUs-0.0.39/3.0/VanDerPol.fmu",

                "${workspaceFolder}/models/PneumaticCylinderController3.fmu"
            ],
            "default": "${workspaceFolder}/models/Reference-FMUs-0.0.39/3.0/BouncingBall.fmu"
        }
    ]
}
