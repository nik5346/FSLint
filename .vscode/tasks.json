{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build All",
            "type": "cmake",
            "command": "build",
            "targets": [
                "FSLint-cli",
                "FSLint-tests"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc",
                "$msCompile"
            ]
        },
        {
            "label": "Build CLI",
            "type": "cmake",
            "command": "build",
            "targets": [
                "FSLint-cli"
            ],
            "group": "build",
            "problemMatcher": [
                "$gcc",
                "$msCompile"
            ]
        },
        {
            "label": "Build Tests",
            "type": "cmake",
            "command": "build",
            "targets": [
                "FSLint-tests"
            ],
            "group": "build",
            "problemMatcher": [
                "$gcc",
                "$msCompile"
            ]
        },
        {
            "label": "Generate Model list in launch.json",
            "type": "shell",
            "command": "python3 scripts/generate_launch.py",
            "problemMatcher": []
        },
        {
            "label": "Download Reference FMUs",
            "type": "shell",
            "command": "python3 scripts/download_reference_fmus.py",
            "problemMatcher": []
        }
    ]
}
