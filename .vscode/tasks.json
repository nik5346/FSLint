{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Current Project",
            "type": "cmake",
            "command": "build",
            "targets": [
                "FSLint-cli",
                "FSLint-tests"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc",
                "$msCompile"
            ]
        },
        {
            "label": "Update FMU list in launch.json",
            "type": "shell",
            "command": "python3 scripts/update_launch.py",
            "problemMatcher": []
        }
    ]
}